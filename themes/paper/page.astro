---
import type { PageData } from "@deepsel/cms-utils";
import { getAttachmentRelativeUrl } from "@deepsel/cms-utils";
import HeaderIsland from "./components/HeaderIsland";
import Footer from "./components/Footer.astro";
import Head from "./components/Head.astro";
import "./main.css";

interface Props {
    data: PageData;
}

const { data } = Astro.props;

const seoMeta = data.seo_metadata;
// featured_image_version_name = AttachmentLocaleVersionModel.name (SEO-friendly storage key).
// Converted to absolute URL because og:image requires a full URL.
const ogImageUrl = seoMeta?.featured_image_version_name
  ? new URL(getAttachmentRelativeUrl(seoMeta.featured_image_version_name), Astro.url).href
  : null;
---

<!DOCTYPE html>
<html lang={data.lang || 'en'} data-theme="paper">
<head>
    <Head />
    <title>{data.seo_metadata?.title || ''}</title>
    <meta name="description" content={data.seo_metadata?.description || ''} />
    <meta name="robots" content={data.seo_metadata?.allow_indexing ? 'index, follow' : 'noindex, nofollow'} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta property="og:title" content={data.seo_metadata?.title || ''} />
    <meta property="og:description" content={data.seo_metadata?.description || ''} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
</head>
<body>
    <div class="min-h-screen flex flex-col">
        <HeaderIsland client:load data={data} />
        <main class="flex-1">
            <div class="page-content max-w-measure mx-auto px-5 py-12">
                <article set:html={data.content} />
            </div>
        </main>
        <Footer siteName={data.public_settings?.name} />
    </div>
</body>
</html>
